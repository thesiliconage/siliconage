---
interface Props {
  title?: string;
  description?: string;
  id?: string;
}

const { title, description, id } = Astro.props;
---

<section class="section" id={id}>
  <div class="container">
    {title && <h2 class="section-title">{title}</h2>}
    {description && <p class="section-desc">{description}</p>}
    <slot />
  </div>
</section>
