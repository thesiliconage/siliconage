---
interface Props {
  icon?: string;
  title: string;
  tag?: string;
  tagType?: 'iris' | 'copper' | 'silicon';
  href?: string;
}

const { icon, title, tag, tagType = 'iris', href } = Astro.props;
---

{href ? (
  <a href={href} class="card card-link">
    {icon && <div class="card-icon" aria-hidden="true">{icon}</div>}
    <div class="card-body">
      <div class="card-head">
        <h3 class="card-title">{title}</h3>
        {tag && <span class={`tag tag-${tagType}`}>{tag}</span>}
      </div>
      <div class="card-text"><slot /></div>
    </div>
  </a>
) : (
  <div class="card">
    {icon && <div class="card-icon" aria-hidden="true">{icon}</div>}
    <div class="card-body">
      <div class="card-head">
        <h3 class="card-title">{title}</h3>
        {tag && <span class={`tag tag-${tagType}`}>{tag}</span>}
      </div>
      <div class="card-text"><slot /></div>
    </div>
  </div>
)}

<style>
  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }
  .card-link:hover { color: inherit; }
  .card-icon {
    font-size: 1.8rem;
    margin-bottom: .75rem;
    line-height: 1;
  }
  .card-head {
    display: flex;
    align-items: center;
    gap: .5rem;
    margin-bottom: .5rem;
    flex-wrap: wrap;
  }
  .card-title {
    font-size: 1.05rem;
    font-weight: 600;
  }
  .card-text {
    color: var(--muted);
    font-size: .9rem;
    line-height: 1.7;
  }
</style>
