---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';

const pageTitle = '关于 | Silicon Age｜硅基时代';
const pageDesc = '关于 Silicon Age｜硅基时代 —— 一个关注人工智能、信息化与具身智能积极作用的非营利公益网站。';
---

<Layout title={pageTitle} description={pageDesc}>

  <PageHero
    title="关于 Silicon Age｜硅基时代"
  />

  <Section>
    <div class="about-content">
      <p><strong>Silicon Age｜硅基时代</strong> 是一个非营利公益网站。</p>

      <p>我们关注人工智能、信息化与具身智能的积极作用，希望用清晰、克制、正向的方式，帮助更多人理解智能时代，并鼓励公众积极、合理、向善地使用技术。</p>
    </div>
  </Section>

  <Section title="联系方式" description="">
    <div class="contact-box">
      <p>如有建议或反馈，可通过以下方式联系：</p>
      <p class="contact-email">contact@example.com</p>

    </div>
  </Section>

</Layout>

<style>
  .about-content {
    max-width: 720px;
    margin: 0 auto;
    background: var(--ink-2);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 2.5rem;
  }
  .about-content p {
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.9;
    margin-bottom: 1.25rem;
  }
  .about-content p:last-child { margin-bottom: 0; }
  .about-content strong { color: var(--paper); }

  .contact-box {
    text-align: center;
    max-width: 480px;
    margin: 0 auto;
    background: var(--ink-2);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 2rem;
  }
  .contact-box p {
    color: var(--muted);
    font-size: .95rem;
  }
  .contact-email {
    font-family: var(--font-mono);
    font-size: 1.05rem !important;
    color: var(--iris) !important;
    margin: .75rem 0;
  }
  .contact-note {
    font-size: .82rem !important;
    opacity: .6;
  }
</style>
