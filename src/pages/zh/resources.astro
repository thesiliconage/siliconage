---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import Section from '../../components/Section.astro';
import Card from '../../components/Card.astro';

const pageTitle = '资源入口 | Silicon Age｜硅基时代';
const pageDesc = '免费、公益、可信的学习资源。';
---

<Layout title={pageTitle} description={pageDesc}>

  <PageHero
    title="资源入口"
    description="免费、公益、可信的学习资源。"
  />

  <Section title="收录原则" description="">
    <div class="grid-3">
      <Card icon="🆓" title="免费优先">
        优先收录免费可用的资源和工具，降低公众获取知识的门槛。
      </Card>
      <Card icon="🤲" title="公益优先">
        优先收录以公益为目的的项目和平台，支持正向价值传播。
      </Card>
      <Card icon="✅" title="可信优先">
        优先收录来源明确、内容可靠、持续维护的资源。
      </Card>
    </div>
  </Section>

  <Section title="当前状态" description="">
    <div class="placeholder-box">
      <div class="placeholder-icon" aria-hidden="true">📦</div>
      <p>资源整理进行中，即将上线。</p>
    </div>
  </Section>

</Layout>

<style>
  .placeholder-box {
    text-align: center;
    padding: 3rem 2rem;
    background: var(--ink-2);
    border: 1px dashed var(--line-2);
    border-radius: var(--radius);
    max-width: 480px;
    margin: 0 auto;
  }
  .placeholder-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }
  .placeholder-box p {
    color: var(--muted);
    font-size: .95rem;
  }
</style>
