---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';

const pageTitle = '积极影响 | Silicon Age｜硅基时代';
const pageDesc = '我们关注那些能够帮助更多人、改善生活、提升效率和促进公共福祉的技术应用。';
---

<Layout title={pageTitle} description={pageDesc}>

  <PageHero
    title="技术落在真实生活里"
    description="我们关注那些能够帮助更多人、改善生活、提升效率和促进公共福祉的技术应用。"
  />

  <Section title="教育支持" description="">
    <div class="single-block">
      <p>技术帮助更多人获得学习资源与个性化学习辅助。在线教育平台让偏远地区的学生也能接触到优质课程，智能辅导系统可以根据每个学生的学习进度提供个性化的学习建议，让教育更加公平和高效。</p>
    </div>
  </Section>

  <Section title="医疗辅助" description="">
    <div class="single-block">
      <p>技术在健康知识普及、辅助筛查和基层服务效率提升方面发挥着积极作用。AI 辅助影像分析可以帮助基层医生提高筛查效率，健康管理应用帮助用户更好地了解和管理自身健康状况，远程医疗让偏远地区居民也能获得专业的健康咨询。</p>
    </div>
  </Section>

  <Section title="无障碍" description="">
    <div class="single-block">
      <p>技术帮助视障、听障、行动不便者更好地参与数字生活。屏幕阅读器让视障人士可以访问网页内容，语音识别让听障人士可以通过文字参与对话，智能假肢和外骨骼让行动不便者重新获得行动能力。</p>
    </div>
  </Section>

  <Section title="科学研究" description="">
    <div class="single-block">
      <p>技术辅助资料整理、模型分析和科研探索。AI 可以帮助研究人员快速筛选和整理海量文献，模拟复杂系统的行为，加速科学发现的进程。从蛋白质结构预测到气候模型模拟，AI 正在成为科学研究的重要工具。</p>
    </div>
  </Section>

  <Section title="公共服务" description="">
    <div class="single-block">
      <p>技术提升信息查询、服务办理和资源配置效率。智能客服可以 24 小时回答市民的常见问题，在线政务平台让群众少跑腿、数据多跑路，智慧城市系统帮助管理者更合理地配置公共资源。</p>
    </div>
  </Section>

  <Section title="环境保护" description="">
    <div class="single-block">
      <p>技术支持环境监测、能源优化和灾害预警等正向场景。卫星遥感和 AI 分析帮助监测森林覆盖变化，智能电网优化能源分配减少浪费，地震预警系统为公众争取宝贵的避险时间。</p>
    </div>
  </Section>

</Layout>

<style>
  .single-block {
    max-width: 720px;
    margin: 0 auto;
    background: var(--ink-2);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 2rem;
  }
  .single-block p {
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.9;
  }
</style>
