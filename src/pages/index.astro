---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';

const pageTitle = 'Silicon Age｜硅基时代｜理解智能时代，善用科技力量';
const pageDesc = '硅基时代是一个非营利公益网站，关注人工智能、信息化与具身智能的积极作用，倡导公众积极、合理、向善地使用技术。';
---

<Layout title={pageTitle} description={pageDesc}>

  <!-- Hero -->
  <Hero
    title="理解智能时代，善用科技力量"
    subtitle="Silicon Age｜硅基时代 是一个非营利公益网站，关注人工智能、信息化与具身智能的积极作用，倡导公众积极、合理、向善地使用技术。"
    primaryHref="/tech"
    primaryLabel="认识技术"
    secondaryHref="/impact"
    secondaryLabel="了解积极影响"
  />

  <!-- 我们关注什么 -->
  <Section title="我们关注什么" description="我们关注能够帮助更多人、改善生活、提升效率和促进公共福祉的技术方向。">
    <div class="grid-3">
      <Card icon="🌐" title="信息化" tag="基础" tagType="silicon">
        数字技术提升信息流通、学习协作、公共服务与社会运行效率。
      </Card>
      <Card icon="🤖" title="人工智能" tag="核心" tagType="iris">
        AI 可以辅助学习、整理信息、激发创造力、提升科研与工作效率。
      </Card>
      <Card icon="🦾" title="具身智能" tag="前沿" tagType="copper">
        机器人与智能设备可以帮助人类完成重复、繁重、危险或人力难及的任务。
      </Card>
    </div>
  </Section>

  <!-- 技术的积极作用 -->
  <Section title="技术的积极作用" description="科技正在以多种方式改善学习、工作、生活和公共服务。">
    <div class="grid-3">
      <Card icon="📚" title="教育支持">
        帮助更多人获得学习资源与个性化学习辅助。
      </Card>
      <Card icon="🏥" title="医疗辅助">
        支持健康知识普及、辅助筛查和基层服务效率提升。
      </Card>
      <Card icon="♿" title="无障碍">
        帮助视障、听障、行动不便者更好地参与数字生活。
      </Card>
      <Card icon="🔬" title="科学研究">
        辅助资料整理、模型分析和科研探索。
      </Card>
      <Card icon="🏛️" title="公共服务">
        提升信息查询、服务办理和资源配置效率。
      </Card>
      <Card icon="🌿" title="环境保护">
        支持环境监测、能源优化和灾害预警等正向场景。
      </Card>
    </div>
  </Section>

  <!-- 如何善用技术 -->
  <Section title="如何善用技术" description="积极使用技术，也要合理使用技术。">
    <div class="grid-4">
      <Card icon="✅" title="核实信息">
        AI 输出需要查证，重要结论不能只依赖自动生成内容。
      </Card>
      <Card icon="🧠" title="保持思考">
        把技术作为助手，而不是替代判断的人。
      </Card>
      <Card icon="🤝" title="尊重他人">
        不使用技术欺骗、骚扰、冒犯或伤害他人。
      </Card>
      <Card icon="🔒" title="保护隐私">
        不输入自己或他人的敏感个人信息。
      </Card>
    </div>
  </Section>

  <!-- 页面入口 -->
  <Section title="了解更多" description="探索网站各部分，了解智能时代的积极价值。">
    <div class="grid-4">
      <Card icon="📖" title="认识技术" href="/tech" tag="入门" tagType="silicon">
        了解人工智能、信息化与具身智能的基本概念。
      </Card>
      <Card icon="💡" title="积极影响" href="/impact" tag="价值" tagType="iris">
        查看技术在教育、医疗辅助、无障碍、环保和公共服务中的正面价值。
      </Card>
      <Card icon="🛡️" title="善用技术" href="/use-well" tag="实践" tagType="copper">
        学习如何积极、合理、安全地使用智能工具。
      </Card>
      <Card icon="🔗" title="资源入口" href="/resources" tag="筹备中" tagType="silicon">
        未来整理免费、公益、可信的学习资源。
      </Card>
    </div>
  </Section>

  <!-- 非营利说明 -->
  <Section>
    <div class="nonprofit-note">
      <p><strong>Silicon Age｜硅基时代</strong> 是一个关注人工智能、信息化与具身智能积极作用的非营利公益网站。</p>
    </div>
  </Section>

</Layout>

<style>
  .nonprofit-note {
    text-align: center;
    padding: 2rem;
    background: var(--ink-2);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    color: var(--muted);
    font-size: .9rem;
  }
</style>
