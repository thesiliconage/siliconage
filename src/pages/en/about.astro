---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import Section from '../../components/Section.astro';

const pageTitle = 'About | Silicon Age';
const pageDesc = 'About Silicon Age — a non-profit website dedicated to the positive impact of AI, digitalization, and embodied intelligence.';
---

<Layout title={pageTitle} description={pageDesc} lang="en">

  <PageHero
    title="About Silicon Age"
  />

  <Section>
    <div class="about-content">
      <p><strong>Silicon Age</strong> is a non-profit website.</p>

      <p>We focus on the positive impact of artificial intelligence, digitalization, and embodied intelligence. We hope to help more people understand the intelligent era in a clear, restrained, and positive way, and encourage the active, responsible, and ethical use of technology.</p>
    </div>
  </Section>

  <Section title="Contact" description="">
    <div class="contact-box">
      <p>For suggestions or feedback, please contact us at:</p>
      <p class="contact-email">contact@example.com</p>
    </div>
  </Section>

</Layout>

<style>
  .about-content {
    max-width: 720px;
    margin: 0 auto;
    background: var(--ink-2);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 2.5rem;
  }
  .about-content p {
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.9;
    margin-bottom: 1.25rem;
  }
  .about-content p:last-child { margin-bottom: 0; }
  .about-content strong { color: var(--paper); }

  .contact-box {
    text-align: center;
    max-width: 480px;
    margin: 0 auto;
    background: var(--ink-2);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 2rem;
  }
  .contact-box p {
    color: var(--muted);
    font-size: .95rem;
  }
  .contact-email {
    font-family: var(--font-mono);
    font-size: 1.05rem !important;
    color: var(--iris) !important;
    margin: .75rem 0;
  }
</style>
