---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import Section from '../../components/Section.astro';
import Card from '../../components/Card.astro';

const pageTitle = 'Use Wisely | Silicon Age';
const pageDesc = 'The value of technology lies in helping people learn, create, collaborate, and live better. Use technology actively and responsibly.';
---

<Layout title={pageTitle} description={pageDesc} lang="en">

  <PageHero
    title="Use Intelligence for the Right Things"
    description="The value of technology lies in helping people learn, create, collaborate, and live better. Use technology actively and responsibly."
  />

  <Section title="Active Use" description="Here are scenarios suitable for using AI and intelligent tools.">
    <div class="grid-3">
      <Card icon="📖" title="Learning Assistance" tag="Recommended" tagType="iris">
        Use AI to help understand concepts, organize notes, generate exercises, and assist language learning.
      </Card>
      <Card icon="📋" title="Organize Materials">
        Use AI to help summarize documents, extract key points, generate abstracts, and organize information.
      </Card>
      <Card icon="💼" title="Boost Work Efficiency">
        Use AI to assist with writing emails, organizing spreadsheets, creating presentations, and managing schedules.
      </Card>
      <Card icon="💡" title="Spark Creativity">
        Use AI for brainstorming, generating creative solutions, and assisting design.
      </Card>
      <Card icon="🤲" title="Support Public Good">
        Use technology to participate in volunteering, information sharing, and community support.
      </Card>
      <Card icon="👨‍👩‍👧" title="Help Family">
        Help family members understand digital services and use intelligent tools to simplify daily life.
      </Card>
    </div>
  </Section>

  <Section title="Responsible Use" description="Basic principles to follow when using technology.">
    <div class="grid-3">
      <Card icon="🔍" title="Verify Sources">
        Content generated by AI should be verified through reliable sources. Do not blindly trust.
      </Card>
      <Card icon="🧠" title="Keep Judgment">
        Use AI as a reference. Final decisions should still be made by humans.
      </Card>
      <Card icon="©️" title="Respect Copyright">
        Be mindful of intellectual property and originality when using AI-generated content.
      </Card>
      <Card icon="🔒" title="Protect Privacy">
        Do not input sensitive personal information about yourself or others into AI.
      </Card>
      <Card icon="❌" title="No Fabrication">
        Do not use AI to fabricate facts, falsify data, or generate false information.
      </Card>
      <Card icon="🤝" title="No Harm">
        Do not use technology to harass, deceive, offend, or manipulate others.
      </Card>
    </div>
  </Section>

  <Section title="Things to Avoid" description="">
    <div class="grid-2">
      <Card icon="🚫" title="Do Not Fabricate Facts" tag="Avoid" tagType="copper">
        Do not use AI to fabricate facts, falsify data, or generate false information.
      </Card>
      <Card icon="🚫" title="Do Not Impersonate Others" tag="Avoid" tagType="copper">
        Do not use AI to impersonate others, forge statements, or deceive people.
      </Card>
      <Card icon="🚫" title="Do Not Share Sensitive Info" tag="Avoid" tagType="copper">
        Do not input ID numbers, bank card numbers, passwords, or other sensitive personal information into AI.
      </Card>
      <Card icon="🚫" title="Do Not Abuse Technology" tag="Avoid" tagType="copper">
        Do not use technology to harass, deceive, or manipulate others. Do not treat AI output as professional conclusions.
      </Card>
    </div>
  </Section>

  <Section title="Privacy Reminder" description="">
    <div class="single-block">
      <p>When using AI tools, please protect your personal privacy. Do not enter your real name, ID number, phone number, address, bank card number, or other sensitive information in conversations. If you need to handle content involving personal privacy, consider using locally deployed tools or anonymizing the data before using online services.</p>
    </div>
  </Section>

</Layout>

<style>
  .single-block {
    max-width: 720px;
    margin: 0 auto;
    background: var(--ink-2);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 2rem;
  }
  .single-block p {
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.9;
  }
</style>
