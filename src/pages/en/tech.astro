---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import Section from '../../components/Section.astro';
import Card from '../../components/Card.astro';

const pageTitle = 'Explore Technology | Silicon Age';
const pageDesc = 'A concise introduction to key technologies of the intelligent era, helping the public build a basic understanding.';
---

<Layout title={pageTitle} description={pageDesc} lang="en">

  <PageHero
    title="Explore Technology — No Expertise Required"
    description="A concise, restrained introduction to the key technologies of the intelligent era, helping the public build a basic understanding."
  />

  <Section title="Digitalization" description="">
    <div class="single-block">
      <p>Digitalization enables more efficient connections between data, processes, and services, making learning, work, and public services more convenient. From e-government to online education, from digital healthcare to smart cities, digitalization is making social operations more transparent and efficient.</p>
    </div>
  </Section>

  <Section title="Artificial Intelligence" description="">
    <div class="single-block">
      <p>Artificial intelligence helps people understand information, generate ideas, organize materials, and improve efficiency. From speech recognition to image understanding, from natural language processing to intelligent recommendations, AI is becoming a powerful assistant for learning and work.</p>
    </div>
  </Section>

  <Section title="Embodied Intelligence" description="">
    <div class="single-block">
      <p>Embodied intelligence connects AI with sensors, robots, and the real world, helping complete tasks in physical environments. From industrial robots to service robots, from autonomous driving to intelligent warehousing, embodied intelligence is expanding the boundaries of human capability.</p>
    </div>
  </Section>

  <Section title="Common Understanding" description="">
    <div class="grid-2">
      <Card icon="⚠️" title="AI Is Not a Silver Bullet">
        AI has its limitations and cannot solve all problems. Understanding its boundaries leads to better use.
      </Card>
      <Card icon="🔍" title="Verify AI Output">
        AI-generated content may contain errors or biases. Important information should be verified through reliable sources.
      </Card>
      <Card icon="🧑‍💼" title="Technology Serves People">
        Technology is a tool to assist humans, not to replace human responsibility and judgment. Key decisions still require human oversight.
      </Card>
      <Card icon="🔐" title="Respect Privacy and Rights">
        When using technology, respect privacy and the rights of others. Do not input sensitive personal information or misuse technological capabilities.
      </Card>
    </div>
  </Section>

</Layout>

<style>
  .single-block {
    max-width: 720px;
    margin: 0 auto;
    background: var(--ink-2);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 2rem;
  }
  .single-block p {
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.9;
  }
</style>
